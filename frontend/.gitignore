# Frontend .gitignore

# ============================================
# CRITICAL: Environment & Secrets
# ============================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.local.example
*.pem

# ============================================
# Dependencies
# ============================================
node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged

# ============================================
# Next.js
# ============================================
.next/
out/
build/
.turbo/

# ============================================
# Testing
# ============================================
coverage/
.nyc_output/
test-results/
playwright-report/

# ============================================
# Logs
# ============================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ============================================
# Deployment
# ============================================
.vercel
.netlify
.firebase/

# ============================================
# OS & Editor Files
# ============================================
.DS_Store
Thumbs.db
*.pem
desktop.ini
.vscode/
!.vscode/extensions.json
.idea/

# ============================================
# Cache
# ============================================
.cache/
.parcel-cache/
.eslintcache
*.tsbuildinfo

# ============================================
# Temporary Files
# ============================================
*.tmp
*.temp
.temp/