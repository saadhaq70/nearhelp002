# Backend .gitignore

# ============================================
# CRITICAL: Environment & Secrets
# ============================================
.env
.env.*
!.env.example
*.pem
*.key
secrets/
config/secrets/

# ============================================
# Dependencies
# ============================================
node_modules/
.pnp
.pnp.js

# ============================================
# Logs
# ============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ============================================
# Database
# ============================================
*.sqlite
*.sqlite3
*.db
drop-and-recreate.sql
*.dump
*.backup

# ============================================
# Prisma
# ============================================
prisma/migrations/*.sql.backup

# ============================================
# Cache
# ============================================
.npm
.eslintcache
.cache/

# ============================================
# OS Files
# ============================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================
# Test & Debug Files
# ============================================
test-*.js
!test-critical-flows.js
scratch_*.js
debug_*.js
temp_*.js

# ============================================
# Build
# ============================================
dist/
build/

# ============================================
# IMPORTANT: Keep these!
# ============================================
!.env.example