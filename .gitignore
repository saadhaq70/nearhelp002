# Root-level .gitignore for nearhelp project

# ============================================
# CRITICAL: Environment & Secrets
# ============================================
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.der
secrets/
config/secrets/

# ============================================
# Dependencies
# ============================================
node_modules/
**/node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
package-lock.json.backup
yarn.lock.backup

# ============================================
# Build Outputs
# ============================================
dist/
build/
out/
.next/
.turbo/
*.tsbuildinfo

# ============================================
# Logs
# ============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ============================================
# Testing & Coverage
# ============================================
coverage/
*.lcov
.nyc_output/
test-results/
playwright-report/

# ============================================
# IDE & Editors
# ============================================
.vscode/
!.vscode/extensions.json
!.vscode/settings.example.json
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
.DS_Store

# ============================================
# OS Files
# ============================================
.DS_Store
Thumbs.db
desktop.ini
*.tmp
*.temp

# ============================================
# Database
# ============================================
*.sqlite
*.sqlite3
*.db
prisma/migrations/*.sql.backup
*.dump

# ============================================
# Deployment & CI/CD
# ============================================
.vercel
.netlify
.firebase/
.serverless/

# ============================================
# Temporary & Cache Files
# ============================================
.cache/
.parcel-cache/
.eslintcache
.npm
.yarn-integrity
*.local

# ============================================
# Documentation Build (if applicable)
# ============================================
docs/.build/
site/

# ============================================
# Custom Test Files
# ============================================
test-*.js
scratch_*.js
debug_*.js
temp_*.js

# ============================================
# IMPORTANT: Keep these examples!
# ============================================
!.env.example
!.env.local.example
!package-lock.json
!yarn.lock
